#!/usr/bin/env bash
# agent-daemon — always-alive, usage-paced supervisor for `/team-pickup`.
#
# The tracer-bullet loop for PRD #287 (issue #288): it establishes the end-to-end
# path sensor -> decision -> action -> schedule with no pause/resume yet.
#
#   1. Sensor  : read the account's REAL utilization (session + weekly) from the
#                OAuth usage endpoint (lib/usage-sensor.sh); fall back to the
#                local `ccusage blocks --json` time-proxy when unreachable.
#   2. Decision: fire when >= BUDGET_GATE_MIN_PCT (default 25) percent of the
#                binding limit's budget remains (plan-agnostic).
#   3. Action  : when enough window remains (>= BUDGET_GATE_MIN_PCT, default 25),
#                fire `agent-run` (which invokes `/team-pickup`). After a clean
#                run the loop goes straight back to the gate and fires again if
#                budget still allows — the backlog drains within one window.
#                agent-run markers steer the exceptions: AGENT_RUN_NO_WORK=1
#                (empty queue) sleeps in chunks with a zero-cost Work Probe
#                that wakes the loop early when work appears mid-window;
#                AGENT_RUN_RESET_AT=<iso> (mid-run exhaustion, issue paused)
#                sleeps to that reset.
#   4. Schedule: the Sleep Planner decides how long to sleep and how to poll after
#                waking; the daemon then sleeps and polls until budget is actually
#                replenished before the next fire.
#
# If `ccusage` is unavailable (e.g. offline) the daemon degrades to a reset
# estimate from the local JSONL mtime and stays alive rather than crashing.
#
# Designed to run under systemd (Restart=always) as the claude-agent user; see
# infra/systemd/agent-daemon.service. Logs go to stdout/stderr (journald).
#
# Everything the loop touches is injectable via env so it is unit-testable
# without the network, the clock, or the Claude CLI:
#   CCUSAGE_CMD           shell command that prints ccusage blocks JSON
#   AGENT_RUN_CMD         path/command to fire one run (default: ./agent-run)
#   SLEEP_CMD             sleep command (default: sleep)
#   CLAUDE_JSONL_DIR      dir scanned for the degraded reset estimate
#   WINDOW_SECS           assumed window length for degraded estimate (default 5h)
#   AGENT_DAEMON_MAX_ITERS  stop after N loop passes (default: unbounded)
#   WORK_PROBE_INTERVAL   secs between mid-sleep work probes (default 900)
#   WORK_PROBE_CMD        command eval'd for a probe scan (default: wp_scan)
#   USAGE_FETCH_CMD       command eval'd for the OAuth usage JSON
#                         (default: usage_sensor_fetch)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/budget-gate.sh
. "${SCRIPT_DIR}/lib/budget-gate.sh"
# shellcheck source=lib/sleep-planner.sh
. "${SCRIPT_DIR}/lib/sleep-planner.sh"
# shellcheck source=lib/work-probe.sh
. "${SCRIPT_DIR}/lib/work-probe.sh"
# shellcheck source=lib/usage-sensor.sh
. "${SCRIPT_DIR}/lib/usage-sensor.sh"

# Pinned ccusage version keeps the sensor reproducible across hosts.
CCUSAGE_VERSION="${CCUSAGE_VERSION:-20.0.14}"
CCUSAGE_CMD="${CCUSAGE_CMD:-npx ccusage@${CCUSAGE_VERSION} blocks --json}"
AGENT_RUN_CMD="${AGENT_RUN_CMD:-${SCRIPT_DIR}/agent-run}"
SLEEP_CMD="${SLEEP_CMD:-sleep}"
CLAUDE_JSONL_DIR="${CLAUDE_JSONL_DIR:-${HOME}/.claude}"
WINDOW_SECS="${WINDOW_SECS:-18000}"
AGENT_DAEMON_MAX_ITERS="${AGENT_DAEMON_MAX_ITERS:-0}"   # 0 = unbounded
WORK_PROBE_INTERVAL="${WORK_PROBE_INTERVAL:-900}"       # secs between probes
WORK_PROBE_CMD="${WORK_PROBE_CMD:-wp_scan}"             # eval'd; emits scan JSON
USAGE_FETCH_CMD="${USAGE_FETCH_CMD:-usage_sensor_fetch}" # eval'd; OAuth usage JSON

log() { echo "[agent-daemon $(date -u +%Y-%m-%dT%H:%M:%SZ)] $*"; }

# Estimate the next reset when ccusage is unavailable: newest JSONL mtime +
# WINDOW_SECS, falling back to now + WINDOW_SECS if nothing is found. Keeps the
# daemon alive and roughly paced instead of crash-looping.
degraded_reset_iso() {
    local newest mtime base est now
    newest="$(ls -t "${CLAUDE_JSONL_DIR}"/*.jsonl 2>/dev/null | head -1 || true)"
    if [ -n "${newest}" ] && [ -f "${newest}" ]; then
        mtime="$(stat -c %Y "${newest}" 2>/dev/null || echo '')"
    fi
    now="$(date -u +%s)"
    base="${mtime:-${now}}"
    est=$((base + WINDOW_SECS))
    # A stale JSONL mtime puts the estimate in the past, which makes the Sleep
    # Planner sleep 0s and then burn its whole poll budget every pass (observed
    # 2026-07-09: hours of "sleeping 0s" + 12×300s polls). Floor at a full
    # window ahead so a degraded daemon backs off instead of spin-polling.
    if [ "${est}" -le "${now}" ]; then
        est=$((now + WINDOW_SECS))
    fi
    date -u -d "@${est}" +%Y-%m-%dT%H:%M:%S.000Z
}

# One sensor+decision read. Sets globals SHOULD_FIRE / RESET_AT / REMAIN_PCT /
# SENSOR. Primary sensor is the OAuth usage endpoint — the account's REAL
# session/weekly utilization, the same numbers the Claude usage UI shows
# (lib/usage-sensor.sh). The ccusage time-proxy only backstops it: it infers a
# window from local JSONL and reports percent of *time* left, which knows
# nothing about actual budget (observed live 2026-07-10: refused to fire at
# "9.72% remaining" while the account sat at 81% real budget free).
read_budget() {
    local json gate_out gate_rc

    json="$(eval "${USAGE_FETCH_CMD}" 2>/dev/null || true)"
    if [ -n "${json}" ]; then
        gate_out="$(printf '%s' "${json}" | usage_gate)" && gate_rc=0 || gate_rc=$?
        if [ "${gate_rc}" -eq 0 ]; then
            SENSOR="oauth"
            SHOULD_FIRE="$(printf '%s' "${gate_out}" | jq -r '.shouldFire')"
            RESET_AT="$(printf '%s' "${gate_out}" | jq -r '.resetAt')"
            REMAIN_PCT="$(printf '%s' "${gate_out}" | jq -r '.remainPct')"
            return 0
        fi
    fi

    json="$(bash -c "${CCUSAGE_CMD}" 2>/dev/null || true)"

    gate_out="$(printf '%s' "${json}" | budget_gate)" && gate_rc=0 || gate_rc=$?

    if [ "${gate_rc}" -eq 0 ]; then
        SENSOR="ccusage-fallback"
        SHOULD_FIRE="$(printf '%s' "${gate_out}" | jq -r '.shouldFire')"
        RESET_AT="$(printf '%s' "${gate_out}" | jq -r '.resetAt')"
        REMAIN_PCT="$(printf '%s' "${gate_out}" | jq -r '.remainPct')"
    else
        # Degraded: never fire; estimate the reset so we can still schedule.
        SENSOR="degraded"
        SHOULD_FIRE="false"
        RESET_AT="$(degraded_reset_iso)"
        REMAIN_PCT="0"
        log "WARN — usage sensor and ccusage both degraded; estimated reset ${RESET_AT}"
    fi
}

# Post-wake poll: the reset estimate may be slightly early, so poll the gate
# until the window is actually fresh (or the poll cap is hit).
budget_poll() {
    local interval="$1" attempts="$2" i
    for ((i = 0; i < attempts; i++)); do
        read_budget
        if [ "${SHOULD_FIRE}" = "true" ]; then
            return 0
        fi
        log "budget not yet replenished (poll $((i + 1))/${attempts}); waiting ${interval}s"
        "${SLEEP_CMD}" "${interval}"
    done
    return 0
}

# Sleep until the reset, then poll until the window is actually fresh (or the
# poll cap is hit). Honors the Sleep Planner's plan.
sleep_and_poll() {
    local reset_at="$1" plan sleep_secs interval attempts
    # BUDGET_GATE_NOW (the test clock pin) also pins the planner's "now".
    plan="$(sleep_planner "${reset_at}" "${BUDGET_GATE_NOW:-}")"
    sleep_secs="$(printf '%s' "${plan}" | jq -r '.sleepSecs')"
    interval="$(printf '%s' "${plan}" | jq -r '.pollIntervalSecs')"
    attempts="$(printf '%s' "${plan}" | jq -r '.pollMaxAttempts')"

    log "sleeping ${sleep_secs}s until reset ${reset_at}"
    "${SLEEP_CMD}" "${sleep_secs}"

    budget_poll "${interval}" "${attempts}"
}

# probe_sleep — chunked sleep-to-reset that wakes early when the Work Probe
# sees actionable work appear mid-window. Used only on the NO_WORK path: the
# budget is there but the queue was empty at fire time, and work arrives on
# human time (a merge that conflicts an open PR, a team:revise hand-back, a
# new issue). Observed live 2026-07-10: a human merge 52s after a no-work
# fire left a CONFLICTING PR waiting ~4h for the window reset. A probe is
# pure `gh` — zero Claude cost. wp_decide's rules keep this loop-proof: a
# held lock never wakes, reconcile/paused wake unconditionally (team-pickup
# deterministically acts on them), and pick-class candidates wake only when
# they differ from the baseline captured here at no-work time.
probe_sleep() {
    local reset_at="$1" plan sleep_secs interval attempts elapsed=0 chunk reason
    local baseline_scan baseline pr_baseline scan
    plan="$(sleep_planner "${reset_at}" "${BUDGET_GATE_NOW:-}")"
    sleep_secs="$(printf '%s' "${plan}" | jq -r '.sleepSecs')"
    interval="$(printf '%s' "${plan}" | jq -r '.pollIntervalSecs')"
    attempts="$(printf '%s' "${plan}" | jq -r '.pollMaxAttempts')"

    # Snapshot both baselines from a single scan: the pick-class signature (new
    # issues) and the open-PR signature (blocker PRs whose merge unblocks the
    # queue). An unreadable PR set snapshots as "" (via // ""), which disables
    # shrink-wake — nothing can "leave" an unknown baseline.
    baseline_scan="$(eval "${WORK_PROBE_CMD}" 2>/dev/null || true)"
    baseline="$(printf '%s' "${baseline_scan}" | jq -r '.pickSig // ""' 2>/dev/null || echo '')"
    pr_baseline="$(printf '%s' "${baseline_scan}" | jq -r '.prSig // ""' 2>/dev/null || echo '')"

    log "sleeping ${sleep_secs}s until reset ${reset_at} (work probe every ${WORK_PROBE_INTERVAL}s)"
    while [ "${elapsed}" -lt "${sleep_secs}" ]; do
        chunk=$((sleep_secs - elapsed))
        if [ "${chunk}" -gt "${WORK_PROBE_INTERVAL}" ]; then
            chunk="${WORK_PROBE_INTERVAL}"
        fi
        "${SLEEP_CMD}" "${chunk}"
        elapsed=$((elapsed + chunk))

        scan="$(eval "${WORK_PROBE_CMD}" 2>/dev/null || true)"
        [ -n "${scan}" ] || continue
        if reason="$(printf '%s' "${scan}" | wp_decide "${baseline}" "${pr_baseline}")"; then
            log "work appeared mid-window (${reason}) — waking early"
            return 0
        fi
    done

    budget_poll "${interval}" "${attempts}"
}

main() {
    log "starting (ccusage='${CCUSAGE_CMD}', max_iters=${AGENT_DAEMON_MAX_ITERS})"
    local iters=0 fire_log run_reset fire_rc
    while true; do
        read_budget
        log "sensor=${SENSOR} remainPct=${REMAIN_PCT} shouldFire=${SHOULD_FIRE} resetAt=${RESET_AT}"

        if [ "${SHOULD_FIRE}" = "true" ]; then
            log "budget above min — firing agent-run"
            # Capture the fire's output (while still streaming it to the journal)
            # so agent-run's markers can steer the next decision. The daemon must
            # survive a non-zero fire and keep pacing.
            fire_log="$(mktemp)"
            # errexit off around the fire: a non-zero agent-run must be handled
            # (backoff below), not abort the daemon. PIPESTATUS[0] is agent-run's
            # own exit, unaffected by the tee.
            set +e
            "${AGENT_RUN_CMD}" 2>&1 | tee "${fire_log}"
            fire_rc="${PIPESTATUS[0]}"
            set -e

            if grep -q '^AGENT_RUN_NO_WORK=1' "${fire_log}"; then
                # Queue empty: re-firing immediately would burn budget on empty
                # picks, but new work arrives on human time — sleep in chunks
                # and let the Work Probe (pure gh, zero Claude cost) wake the
                # loop early when something actionable appears.
                log "queue empty — sleeping until window reset (with work probe)"
                probe_sleep "${RESET_AT}"
            elif grep -q '^AGENT_RUN_RESET_AT=' "${fire_log}"; then
                # Run was cut off by usage exhaustion (issue paused). Sleep to
                # the run's own scraped reset, falling back to the window's.
                run_reset="$(grep -m1 '^AGENT_RUN_RESET_AT=' "${fire_log}" | cut -d= -f2-)"
                [ -n "${run_reset}" ] || run_reset="${RESET_AT}"
                log "run exhausted usage — sleeping until ${run_reset}"
                sleep_and_poll "${run_reset}"
            elif [ "${fire_rc}" -ne 0 ]; then
                # Genuine failure (exit non-zero, no exhaustion/no-work marker).
                # Re-firing immediately would hot-loop on the same broken pick and
                # burn the whole window (observed 2026-07-08: 1271 fires in 2h).
                # A real failure will not fix itself — sleep out the window and
                # let the next reset (or a human) clear it.
                log "WARN — agent-run failed (exit ${fire_rc}) — sleeping until window reset"
                sleep_and_poll "${RESET_AT}"
            else
                # Run finished with budget possibly to spare: loop straight back
                # to the gate and keep working through the backlog this window.
                log "run complete — re-checking budget"
            fi
            rm -f "${fire_log}"
        else
            sleep_and_poll "${RESET_AT}"
        fi

        iters=$((iters + 1))
        if [ "${AGENT_DAEMON_MAX_ITERS}" -ne 0 ] && [ "${iters}" -ge "${AGENT_DAEMON_MAX_ITERS}" ]; then
            log "reached max iters (${AGENT_DAEMON_MAX_ITERS}) — exiting"
            break
        fi
    done
}

main "$@"
