#!/usr/bin/env bash
# agent-run — VM wrapper that fires `/team-pickup` autonomously, no human prompts.
#
# One fire = one issue picked, implemented, PR opened, CI watched to verdict.
# Designed to run on the claude-agent-1 Proxmox VM (see docs/CI-CD/claude-agent-vm.md).
# Cron / scheduler (or agent-daemon) invokes this; output goes to a timestamped
# log under ~/claude-agent/logs/ AND stdout so cron mailers can capture summaries.
#
# After the fire, the Exhaustion Classifier inspects the captured output + exit
# code. If the run was cut off by Claude usage exhaustion, agent-run PAUSES the
# in-flight issue instead of failing: it freezes partial work with a `wip:`
# commit, flips the issue `team:in-progress -> team:paused` (leaving the branch
# intact), records the pause as a timestamped comment, emits any scraped reset
# instant for the daemon, and exits 0 — an out-of-gas event is never a failure.
#
# Usage:
#   agent-run                     # fire once, exit per the classification below
#   agent-run --dry-run           # forward --dry-run to /team-pickup
#
# Exit codes:
#   0   — /team-pickup completed cleanly, OR the run was paused (EXHAUSTED):
#         partial work is frozen and the issue is left in team:paused for resume.
#   non-0 — /team-pickup genuinely failed (§6b path); cron mailer should escalate.
#
# Injectable for tests (default to the real binaries):
#   CLAUDE_BIN  claude CLI          GH_BIN  gh CLI          GIT_BIN  git

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/exhaustion-classifier.sh
. "${SCRIPT_DIR}/lib/exhaustion-classifier.sh"

REPO_DIR="${REPO_DIR:-$HOME/Smart-Smoker-V2}"
LOG_DIR="${LOG_DIR:-$HOME/claude-agent/logs}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
GH_BIN="${GH_BIN:-gh}"
GIT_BIN="${GIT_BIN:-git}"
TS="$(date -u +%Y%m%dT%H%M%SZ)"
LOG_FILE="$LOG_DIR/team-pickup-$TS.log"

mkdir -p "$LOG_DIR"

if [ ! -d "$REPO_DIR/.git" ]; then
  echo "agent-run: ERROR — $REPO_DIR is not a git checkout" >&2
  exit 2
fi

if ! command -v "$CLAUDE_BIN" >/dev/null 2>&1; then
  echo "agent-run: ERROR — claude CLI ($CLAUDE_BIN) not on PATH" >&2
  exit 2
fi

cd "$REPO_DIR"

# Refresh master so /team-pickup §4 branches from up-to-date origin/master.
"$GIT_BIN" fetch --quiet origin master || {
  echo "agent-run: WARN — git fetch failed, continuing with cached refs" | tee -a "$LOG_FILE"
}

# Every fire starts from the tip of master: a prior run may have left the
# checkout on its feat/issue-N branch or with crash debris in the tree.
# Anything worth keeping is already committed on its own branch (an exhausted
# run freezes partial work with a wip commit before pausing), so discarding
# local state here loses nothing.
"$GIT_BIN" reset --hard --quiet || true
"$GIT_BIN" checkout --quiet master || {
  echo "agent-run: ERROR — cannot checkout master in $REPO_DIR" >&2
  exit 2
}
"$GIT_BIN" reset --hard --quiet origin/master || {
  echo "agent-run: WARN — reset to origin/master failed, continuing on local master" | tee -a "$LOG_FILE"
}

DRY_RUN_FLAG=""
if [ "${1:-}" = "--dry-run" ]; then
  DRY_RUN_FLAG=" --dry-run"
fi

echo "=== agent-run $TS ===" | tee -a "$LOG_FILE"
echo "repo:   $REPO_DIR"      | tee -a "$LOG_FILE"
echo "log:    $LOG_FILE"      | tee -a "$LOG_FILE"
echo "prompt: /team-pickup$DRY_RUN_FLAG" | tee -a "$LOG_FILE"
echo                          | tee -a "$LOG_FILE"

# `/team-pickup` spawns background subagents (implementer/reviewer/verifier) that
# routinely run well past `claude --print`'s default 600s background-task ceiling.
# Left at the default, print terminates the team mid-dispatch and returns exit 0
# with no PR and the issue still locked. 0 = wait indefinitely. Honor a host
# override (e.g. the systemd EnvironmentFile drop-in) if one is already set.
export CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS="${CLAUDE_CODE_PRINT_BG_WAIT_CEILING_MS:-0}"

set +e
"$CLAUDE_BIN" \
  --permission-mode bypassPermissions \
  --print \
  "/team-pickup$DRY_RUN_FLAG" \
  2>&1 | tee -a "$LOG_FILE"
EXIT_CODE=${PIPESTATUS[0]}
set -e

echo                                       | tee -a "$LOG_FILE"
echo "=== agent-run exit $EXIT_CODE ===" | tee -a "$LOG_FILE"

# Classify the run from its captured output + exit code: OK / EXHAUSTED / FAILED.
VERDICT="$(exhaustion_classify "$EXIT_CODE" < "$LOG_FILE")"
STATUS="$(printf '%s' "$VERDICT" | jq -r '.status')"
RESET_AT="$(printf '%s' "$VERDICT" | jq -r '.resetAt')"

# pause_inflight — freeze partial work and move the in-flight issue to
# team:paused. Every step is best-effort (|| true): a pause must never itself
# fail the run and re-wedge the pipeline. team:failed is never applied here.
pause_inflight() {
  local reset_at="$1" issue ts note

  issue="$("$GH_BIN" issue list --label team:in-progress --state open \
    --json number --jq '.[0].number' 2>/dev/null || true)"
  if [ -z "$issue" ] || [ "$issue" = "null" ]; then
    echo "agent-run: EXHAUSTED but no team:in-progress issue to pause" | tee -a "$LOG_FILE"
    return 0
  fi

  # Freeze any partial edits so the next checkout does not lose uncommitted work.
  "$GIT_BIN" add -A || true
  if ! "$GIT_BIN" diff --cached --quiet 2>/dev/null; then
    "$GIT_BIN" commit -m "wip: freeze partial work on #${issue} (usage exhausted)" || true
  fi

  # Flip the lock to paused, keeping the branch intact for resume next window.
  "$GH_BIN" issue edit "$issue" \
    --remove-label team:in-progress --add-label team:paused || true

  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  note="Run paused at ${ts} — Claude usage exhausted mid-run. Branch kept for resume."
  if [ -n "$reset_at" ]; then
    note="${note} Budget resets at ${reset_at}."
  fi
  "$GH_BIN" issue comment "$issue" --body "$note" || true

  echo "agent-run: paused #${issue} (team:in-progress -> team:paused)" | tee -a "$LOG_FILE"
}

# fail_inflight — on a genuine failure, clear the lock THIS run created so the
# next fire is not blocked forever. Scoped to the issue this run picked (scraped
# from the `picked:   #N` line in this run's own log): if claude crashed before
# team-pickup's §6b could clean up, the team:in-progress lock leaks and every
# future fire skips (observed 2026-07-08: #280 stuck for a day). Never touches a
# lock this run did not create. Idempotent with §6b (best-effort, || true).
fail_inflight() {
  local issue ts
  issue="$(grep -oE 'picked:[[:space:]]+#[0-9]+' "$LOG_FILE" | grep -oE '[0-9]+' | head -1 || true)"
  if [ -z "$issue" ]; then
    echo "agent-run: FAILED with no issue picked — no lock to clear" | tee -a "$LOG_FILE"
    return 0
  fi

  "$GH_BIN" issue edit "$issue" \
    --remove-label team:in-progress --add-label team:failed || true

  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  "$GH_BIN" issue comment "$issue" \
    --body "Run failed at ${ts} — team-pickup fire exited non-zero. Lock cleared (team:in-progress → team:failed) for human triage." || true

  echo "agent-run: failed #${issue} (team:in-progress -> team:failed)" | tee -a "$LOG_FILE"
}

case "$STATUS" in
  EXHAUSTED)
    echo "agent-run: EXHAUSTED — pausing in-flight work; resetAt=${RESET_AT}" | tee -a "$LOG_FILE"
    pause_inflight "$RESET_AT"
    # Emit the scraped reset instant on a stable line for the daemon to schedule off.
    echo "AGENT_RUN_RESET_AT=${RESET_AT}" | tee -a "$LOG_FILE"
    exit 0
    ;;
  FAILED)
    echo "agent-run: FAILED — exit $EXIT_CODE" | tee -a "$LOG_FILE"
    fail_inflight
    exit "$EXIT_CODE"
    ;;
  *)
    # Clean run that picked nothing (empty queue or a stale in-flight skip):
    # tell the daemon so it sleeps out the window instead of re-firing into an
    # empty pick loop. Match both the stable machine lines the skill emits
    # (`team-pickup: skip` / `team-pickup: no eligible issue`) and the human
    # report line (`picked:   skip — N in flight`) observed live 2026-07-09 —
    # missing the latter made the daemon treat a skip as a clean run and
    # hot-loop into the lock.
    if grep -qE 'team-pickup: (no eligible issue|skip)|^[[:space:]]*picked:[[:space:]]+(skip|no eligible)' "$LOG_FILE"; then
      echo "AGENT_RUN_NO_WORK=1" | tee -a "$LOG_FILE"
    fi
    exit "$EXIT_CODE"
    ;;
esac
