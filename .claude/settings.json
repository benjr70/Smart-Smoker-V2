    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(docker compose down*)",
      "Bash(docker compose rm*)",
      "Bash(rm -rf*)"
    ]
  }
