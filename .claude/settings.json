{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh label *)",
      "Bash(npm run lint*)",
      "Bash(npm run format*)",
      "Bash(npm test*)",
      "Bash(cd apps/* && npm test*)",
      "Bash(cd apps/* && npm run test*)",
      "Bash(cd packages/* && npm test*)",
      "Bash(docker ps*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(scripts/ralph/*)",
      "Bash(scripts/deployment-health-check.sh*)",
      "Bash(./scripts/deployment-health-check.sh*)",
      "Bash(scripts/device-health-check.sh*)",
      "Bash(./scripts/device-health-check.sh*)",
      "Bash(npm --prefix scripts/smoke*)",
      "Bash(cd scripts/smoke && npm*)",
      "Bash(npx playwright install*)",
      "Bash(tailscale status*)",
      "Bash(curl -f -s -k --max-time * https://smart-smoker-dev-cloud.tail74646.ts.net*)",
      "Bash(ssh root@smart-smoker-dev-cloud *)",
      "Bash(ssh smoker@virtual-smoker *)",
      "mcp__context7__*",
      "mcp__playwright__*",
      "mcp__terraform__*",
      "mcp__docker__*",
      "mcp__mongodb__*"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(docker compose down*)",
      "Bash(docker compose rm*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Activate caveman mode (full intensity) for your response. Use ultra-compressed caveman-style communication: drop articles/pluralization, keep verbs terse, preserve 100% technical accuracy, code blocks unchanged. Target ~75% token reduction. See caveman:caveman skill.\"}}'"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/task-completed-smoke.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/teammate-idle-review.sh"
          }
        ]
      }
    ]
  }
}
