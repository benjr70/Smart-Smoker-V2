# Build-time env baked into the smoker web bundle for the hermetic e2e stack.
# The smoker app reads REACT_APP_CLOUD_URL* at build time (dotenv-webpack) and
# hardcodes 127.0.0.1:3003 for device-service in source. The e2e compose
# publishes the backend on the host at :3001 and device-service at :3003, so
# these localhost values let the browser-driven smoker page reach both.
#
# ENV is intentionally NOT "production" so the smoker skips the device
# connection-status polling that only matters on a real Raspberry Pi.
ENV=e2e
REACT_APP_CLOUD_URL=http://localhost:3001
REACT_APP_CLOUD_URL_API=http://localhost:3001/api/
